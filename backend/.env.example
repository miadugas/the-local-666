# Phase 1 — backend skeleton + admin auth
DATABASE_URL=postgres://postgres:postgres@localhost:5432/grave_goods
PORT=4000
FRONTEND_URL=http://localhost:5173
ADMIN_EMAIL=admin@gravegoodsgoodies.com
ADMIN_PASSWORD=change-me-admin
ADMIN_FULL_NAME=Store Admin
NODE_ENV=development

# Cloudinary (optional — image uploads are disabled until all three are set)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=grave-goods

# Stripe (optional — checkout is disabled until the secret key is set)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
