{
  "name": "@grave-goods/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && rm -rf dist/db/migrations && cp -R src/db/migrations dist/db/migrations",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts up"
  },
  "dependencies": {
    "@grave-goods/shared": "*",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.0.0",
    "pg": "^8.13.1",
    "resend": "^6.12.3",
    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^24.12.3",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "~6.0.2"
  }
}
